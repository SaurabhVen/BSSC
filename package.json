{
  "name": "candidate-portal-backend",
  "version": "1.0.0",
  "description": "Enterprise-grade serverless backend for Candidate Portal (TypeScript)",
  "main": "dist/handlers/auth.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "serverless offline start --host 0.0.0.0 --httpPort 3000",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node src/database/migrate.ts",
    "seed": "ts-node src/database/seeders/index.ts",
    "db:truncate": "ts-node src/database/truncate.ts",
    "db:fresh": "npm run db:truncate && npm run seed",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "echo \"No tests configured\" && exit 0",
    "test:unit": "echo \"No tests configured\" && exit 0",
    "test:integration": "echo \"No tests configured\" && exit 0"
  },
  "dependencies": {
    "@aws-crypto/client-node": "^5.0.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.500.0",
    "@aws-sdk/client-kms": "^3.1069.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/client-ses": "^3.1069.0",
    "@aws-sdk/client-sns": "^3.1069.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "bcryptjs": "^2.4.3",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "exceljs": "^4.4.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "pg": "^8.11.5",
    "razorpay": "^2.9.4",
    "svg-captcha": "^1.4.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.11.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.21.4",
    "eslint": "^9.2.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "serverless": "^3.38.0",
    "serverless-offline": "^13.3.3",
    "serverless-plugin-typescript": "^2.1.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.60.1"
  }
}
