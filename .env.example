# Application Settings
NODE_ENV=development
PORT=3000

# Database Settings
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/candidate_portal

# AWS General Settings
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=mock-access-key-id
AWS_SECRET_ACCESS_KEY=mock-secret-access-key

# AWS Cognito Settings
COGNITO_USER_POOL_ID=us-east-1_mockPoolId
COGNITO_CLIENT_ID=mockClientId1234567890
COGNITO_CLIENT_SECRET=mockClientSecret1234567890

# JWT & Crypto Secrets (for Local verification fallback)
JWT_SECRET=super-secret-jwt-key-for-local-development-only-12345678

# AWS S3 Settings
S3_BUCKET=candidate-portal-documents-bucket

# AWS Secrets Manager
SECRETS_MANAGER_NAME=candidate-portal/secrets

# Mock Options (set to true for offline local testing without AWS dependencies)
MOCK_COGNITO=true
MOCK_S3=true
MOCK_PAYMENT=true
MOCK_SMS_EMAIL=true
